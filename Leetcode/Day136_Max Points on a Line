#include <vector>
#include <numeric>
#include <map>
#include <algorithm>

using namespace std;

class Solution {
public:
    int maxPoints(vector<vector<int>>& points) {
        int n = points.size();
        if (n <= 2) return n;

        int max_points = 1;

        for (int i = 0; i < n; ++i) {
            map<pair<int, int>, int> slopes;
            int local_max = 0;

            for (int j = i + 1; j < n; ++j) {
                int dx = points[j][0] - points[i][0];
                int dy = points[j][1] - points[i][1];

                int common = gcd(dx, dy);
                dx /= common;
                dy /= common;

                if (dx < 0) {
                    dx = -dx;
                    dy = -dy;
                } else if (dx == 0) {
                    dy = abs(dy);
                }

                slopes[{dx, dy}]++;
                local_max = max(local_max, slopes[{dx, dy}]);
            }
            max_points = max(max_points, local_max + 1);
            }

            return max_points;
            }
};

