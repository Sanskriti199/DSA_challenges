class Solution {
public:
    double myPow(double x, int n) {
        long long exp = n;
        double res = 1.0;
        double base = x;
        if (exp < 0) {
            base = 1.0 / x;
            exp = -exp;
        }
        while (exp > 0) {
            if (exp & 1) {
                res *= base;
            }
            base *= base;
            exp >>= 1;
         }
            return res;
         }
};



