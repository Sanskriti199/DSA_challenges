class Solution {
public:
    int singleNumber(vector<int>& nums) {
        int result = 0;
        for (int bit = 0; bit < 32; ++bit) {
            int count = 0;
            for (int num : nums) {
                count += (num >> bit) & 1;
            }
            result |= (count % 3) << bit;
            }
                return result;
            }
};
