class Solution {
  public:
    int countWays(int n) {
        // your code here
        if(n<=1)
        return 1;
        
        long long prev2=1;
        long long prev1=1;
        long long current;
        int mod=1e9+7;
        
        for(int i=2;i<=n;i++){
            current=(prev1+prev2)%mod;
            
            prev2=prev1;
            prev1=current;
        }
        return(int) prev1;
    }
};
