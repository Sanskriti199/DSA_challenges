class Solution {
  public:
    int count(vector<int>& coins, int sum) {
        // code here.
        vector<int> dp(sum+1,0);
        dp[0]=1;
        
        for(int coin:coins){
            for(int i=coin;i<=sum;i++){
                dp[i]+=dp[i-coin];
            }
        }
        return dp[sum];
    }
};
